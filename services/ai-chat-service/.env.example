# CppAIService Environment Configuration Template
# Copy this file to .env and fill in your configuration
#
# IMPORTANT: In Docker Compose environment, use Docker service names as hostnames
# (e.g., mysql, rabbitmq instead of localhost)

#===============================================================================
# Docker Services (DO NOT change these when using docker-compose)
#===============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=chatserver

#===============================================================================
# AI API Keys
#===============================================================================
# Alibaba Cloud DashScope API Key (Required for chat features)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
AI_MODEL=qwen-plus
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_REQUEST_TIMEOUT_SECONDS=60
AI_CONNECT_TIMEOUT_SECONDS=10
AI_STREAM_IDLE_TIMEOUT_SECONDS=90

# Alibaba Cloud Knowledge Base ID (Required for RAG features)
# KNOWLEDGE_BASE_ID=your_knowledge_base_id_here

# Doubao API Key (Optional, for Doubao AI features)
# DOUBAO_API_KEY=your_doubao_api_key_here

# Baidu Speech Synthesis Config (Optional)
# BAIDU_CLIENT_ID=your_baidu_client_id_here
# BAIDU_CLIENT_SECRET=your_baidu_client_secret_here

#===============================================================================
# Server Configuration
#===============================================================================
HTTP_PORT=80
